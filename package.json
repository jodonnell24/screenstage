{
  "name": "motion-creator",
  "version": "0.1.0",
  "description": "TypeScript CLI for cursor-following product demo videos with Playwright and FFmpeg.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "motion-creator": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "find dist -mindepth 1 -delete",
    "dev": "tsx src/cli.ts",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "browser-capture",
    "capture",
    "cli",
    "demo",
    "editing",
    "playwright",
    "ffmpeg",
    "video",
    "cursor",
    "marketing",
    "motion",
    "product-demo",
    "screen-recording"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
